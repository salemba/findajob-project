# ============================================================
# Job Search App - Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Application ---
APP_NAME="Job Search Manager"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development  # development | staging | production

# --- Database ---
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://jobsearch:jobsearch_password@localhost:5432/jobsearch_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Security ---
SECRET_KEY=your-super-secret-key-change-me-in-production-min-32-chars
ALGORITHM=HS256

# --- Anthropic (Claude AI) ---
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-opus-4-5
ANTHROPIC_MAX_TOKENS=4096

# --- CORS / Frontend ---
FRONTEND_URL=http://localhost:5173
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Email Alerts (optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_FROM=your-email@gmail.com
ALERT_EMAIL_TO=your-email@gmail.com

# --- Export ---
EXPORT_DIR=/tmp/exports
